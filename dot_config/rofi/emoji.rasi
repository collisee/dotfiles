@theme "catppuccin-default"
window {
	width:       720px;
}
listview {
  columns:       9;
  lines:         7;
  cycle:         true;
  dynamic:       true;
  layout:        vertical;
  flow:          horizontal;
  reverse:       false;
  fixed-height:  true;
  fixed-columns: true;
}

element {
  orientation: vertical;
 
}

element-text {
  horizontal-align: 0.5;
  font:            "Noto Color Emoji 24";
  padding: 12px 0px 36px 0px;
}
